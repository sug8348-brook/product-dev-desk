{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "product-dev-desk",
  "version": "0.1.0",
  "identifier": "com.sugubrook.productdevdesk",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Product Dev Desk",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:product-dev-desk.db"]
    }
  }
}
